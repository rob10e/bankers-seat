{
  "ConnectionStrings": {
    "BankersSeat": "Data Source=bankers-seat.db",
    "BankersSeatPostgres": "Host=localhost;Port=5432;Database=bankers_seat;Username=postgres;Password=postgres;Pooling=true;Maximum Pool Size=25"
  },
  "DatabaseProvider": "Sqlite",
  "Jwt": {
    "SigningKey": "your-256-bit-secret-key-change-in-production-minimum-32-characters-required",
    "Issuer": "bankers-seat",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ApplicationInsights": {
    "InstrumentationKey": ""
  },
  "IpRateLimit": {
    "IpWhitelist": [],
    "GeneralRules": [
      {
        "Endpoint": "*:/api/v1/sessions/join",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "*:/api/v1/auth/login",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "*:/api/v1/auth/register",
        "Period": "1h",
        "Limit": 3
      }
    ]
  },
  "DataRetention": {
    "IncompleteSessionTtlDays": 7,
    "CompletedSessionTtlDays": 365,
    "LedgerArchiveAfterDays": 90,
    "AutoDeleteEnabled": false
  }
}
